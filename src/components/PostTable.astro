---
import type { CollectionEntry } from "astro:content";
import { getBlogSlug } from "../data/blog";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const badgePalette = [
  { background: "#d4a72c", text: "#111111" },
  { background: "#177a45", text: "#ffffff" },
  { background: "#1e4d8c", text: "#ffffff" },
  { background: "#c41e3a", text: "#ffffff" },
  { background: "#e85d04", text: "#111111" },
  { background: "#7c3aed", text: "#ffffff" },
  { background: "#4b5563", text: "#ffffff" },
];

function formatShortDate(date: Date) {
  return new Intl.DateTimeFormat("en-US", {
    month: "2-digit",
    day: "2-digit",
    year: "2-digit",
    timeZone: "UTC",
  }).format(date);
}

function getCategory(post: CollectionEntry<"blog">) {
  return post.data.series ? `${post.data.series} series` : (post.data.tags[0] ?? "NOTE").toUpperCase();
}

function getRowLabel(post: CollectionEntry<"blog">, index: number) {
  if (post.data.seriesOrder) {
    return `Part ${post.data.seriesOrder}`;
  }

  if (post.data.featured) {
    return "Featured";
  }

  return String(index + 1).padStart(2, "0");
}

function getBadgeTheme(seed: string) {
  let hash = 0;

  for (const char of seed) {
    hash = (hash * 31 + char.charCodeAt(0)) | 0;
  }

  return badgePalette[Math.abs(hash) % badgePalette.length];
}
---

<div class="post-table">
  <div class="post-table-head">
    <div>Date</div>
    <div>Title</div>
    <div>Category</div>
    <div>Tags</div>
  </div>

  {posts.map((post, index) => {
    const category = getCategory(post);
    const badgeTheme = getBadgeTheme(category);
    const href = `${baseUrl}blog/${getBlogSlug(post.id)}/`;

    return (
      <a class="post-table-row" href={href}>
        <div class="post-table-cell post-date">{formatShortDate(post.data.publishedAt)}</div>

        <div class="post-table-cell post-title-cell">
          <div class="post-table-title-line">
            <span class="post-title-link">{post.data.title}</span>
            <span class="row-index">{getRowLabel(post, index)}</span>
          </div>
          <p class="post-table-summary">{post.data.summary}</p>
        </div>

        <div class="post-table-cell post-category">
          <span
            class="panel-tag"
            style={`--tag-color: ${badgeTheme.background}; --tag-text: ${badgeTheme.text};`}
          >
            {category}
          </span>
        </div>

        <div class="post-table-cell post-tags">{post.data.tags.join(", ")}</div>
      </a>
    );
  })}
</div>
