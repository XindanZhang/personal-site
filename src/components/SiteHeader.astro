---
import { site } from "../data/site";

interface Props {
  active?: "home" | "blog" | "none";
  utilityHref?: string;
  utilityLabel?: string;
}

const {
  active = "none",
  utilityHref = site.links.github,
  utilityLabel = "GH",
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const stripColors = [
  "#c41e3a",
  "#e85d04",
  "#1e4d8c",
  "#2563eb",
  "#06b6d4",
  "#d4a72c",
  "#a855f7",
  "#1e1e1e",
  "#e5e5e5",
  "#d4d4d4",
  "#c4c4c4",
  "#b4b4b4",
  "#a4a4a4",
  "#949494",
  "#1e1e1e",
  "#177a45",
  "#2563eb",
  "#7c3aed",
  "#c41e3a",
  "#e85d04",
];
const tabs = [
  { key: "home", label: "Home", href: baseUrl },
  { key: "blog", label: "Blog", href: `${baseUrl}blog/` },
  { key: "github", label: "GitHub", href: site.links.github, external: true },
  { key: "email", label: "Email", href: site.links.email, external: false },
];
const utilityIsExternal = utilityHref.startsWith("http");
---

<header class="site-header">
  <div class="masthead-row">
    <a class="brand-wordmark" href={baseUrl}>{site.name}</a>

    <div class="color-strip" aria-hidden="true">
      {stripColors.map((color) => <span style={`background-color: ${color};`}></span>)}
    </div>

    <a
      class="utility-badge"
      href={utilityHref}
      target={utilityIsExternal ? "_blank" : undefined}
      rel={utilityIsExternal ? "noopener" : undefined}
    >
      {utilityLabel}
    </a>
  </div>

  <nav class="site-nav" aria-label="Primary">
    {tabs.map((tab) => {
      const isActive = active === tab.key;

      return (
        <a
          class:list={["nav-tab", isActive && "is-active"]}
          href={tab.href}
          target={tab.external ? "_blank" : undefined}
          rel={tab.external ? "noopener" : undefined}
        >
          {isActive ? <span class="nav-dot" aria-hidden="true"></span> : null}
          <span>{tab.label}</span>
        </a>
      );
    })}
  </nav>
</header>
