---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings?: Heading[];
}

const { headings = [] } = Astro.props;
const tocItems = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<aside class="toc-panel">
  <div class="toc-panel-title">TABLE OF CONTENTS</div>

  {tocItems.length > 0 ? (
    <nav class="toc-links" aria-label="Table of contents">
      {tocItems.map((heading) => (
        <a class:list={["toc-link", heading.depth === 3 && "is-sub"]} href={`#${heading.slug}`}>
          {heading.text}
        </a>
      ))}
    </nav>
  ) : (
    <p class="toc-empty">This note is short enough that it does not need a section map yet.</p>
  )}
</aside>
