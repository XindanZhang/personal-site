---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { formatBlogDate, getBlogSeries, getBlogSlug } from "../../../data/blog";
import { site } from "../../../data/site";

export async function getStaticPaths() {
  const seriesGroups = await getBlogSeries();

  return seriesGroups.map((series) => ({
    params: { series: series.slug },
    props: { series },
  }));
}

const { series } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const homeHref = baseUrl;
const blogHref = `${baseUrl}blog/`;
---

<BaseLayout
  title={`${series.name} series · ${site.name}`}
  description={`Posts collected under the ${series.name} series.`}
>
  <div class="page-glow page-glow-left"></div>
  <div class="page-glow page-glow-right"></div>
  <div class="grid-haze"></div>

  <main class="site-shell" id="main-content">
    <nav class="topbar" aria-label="Primary">
      <a class="brand-lockup" href={homeHref}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-copy">
          <strong>{site.name}</strong>
          <span>Series view</span>
        </span>
      </a>

      <div class="topbar-links">
        <a href={homeHref}>Home</a>
        <a href={blogHref}>Blog</a>
        <a href={site.links.github} target="_blank" rel="noopener">GitHub</a>
      </div>
    </nav>

    <section class="page-hero">
      <p class="eyebrow">Series</p>
      <h1 class="page-title">{series.name} series</h1>
      <p class="section-copy page-copy">
        Posts collected under one thread so it is easier to follow future updates.
      </p>
      {series.posts[0]?.data.sourceUrl ? (
        <div class="page-actions">
          <a
            class="button button-primary"
            href={series.posts[0].data.sourceUrl}
            target="_blank"
            rel="noopener"
          >
            Official site
          </a>
        </div>
      ) : null}
    </section>

    <div class="blog-grid">
      {series.posts.map((post) => (
        <a class="blog-card" href={`${blogHref}${getBlogSlug(post.id)}/`}>
          <div class="blog-card-meta">
            <span>{formatBlogDate(post.data.publishedAt, "medium")}</span>
            {post.data.seriesOrder ? <span>Part {post.data.seriesOrder}</span> : null}
          </div>
          <h2>{post.data.title}</h2>
          <p>{post.data.summary}</p>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
