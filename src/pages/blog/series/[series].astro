---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostTable from "../../../components/PostTable.astro";
import SiteFooter from "../../../components/SiteFooter.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import { getBlogSeries } from "../../../data/blog";
import { site } from "../../../data/site";

export async function getStaticPaths() {
  const seriesGroups = await getBlogSeries();

  return seriesGroups.map((series) => ({
    params: { series: series.slug },
    props: { series },
  }));
}

const { series } = Astro.props;
const blogHref = `${import.meta.env.BASE_URL}blog/`;
---

<BaseLayout
  title={`${series.name} series · ${site.name}`}
  description={`Posts collected under the ${series.name} series.`}
>
  <main class="site-frame" id="main-content">
    <SiteHeader active="blog" />

    <section class="window-panel">
      <section class="panel-section">
        <div class="section-heading">
          <h1 class="panel-title">{series.name} series</h1>
          <hr />
        </div>

        <p class="section-copy">
          Posts collected under one thread so it is easier to follow future updates.
        </p>
      </section>

      <hr class="panel-divider" />

      <section class="panel-section">
        <div class="section-heading">
          <h2 class="panel-title panel-title-secondary">Series overview</h2>
          <hr />
        </div>

        <p class="section-copy">Every published note in this thread, ordered for easy reading.</p>

        <div class="action-row">
          {series.posts[0]?.data.sourceUrl ? (
            <a
              class="tool-button tool-button-accent"
              href={series.posts[0].data.sourceUrl}
              target="_blank"
              rel="noopener"
            >
              Official site
            </a>
          ) : null}

          <a class="tool-button" href={blogHref}>Back to archive</a>
        </div>
      </section>

      <hr class="panel-divider" />

      <section class="panel-section">
        <PostTable posts={series.posts} />
      </section>
    </section>

    <SiteFooter />
  </main>
</BaseLayout>
