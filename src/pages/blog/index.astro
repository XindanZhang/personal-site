---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostTable from "../../components/PostTable.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { getBlogPosts, getBlogSeries } from "../../data/blog";
import { site } from "../../data/site";

const baseUrl = import.meta.env.BASE_URL;
const posts = await getBlogPosts();
const seriesGroups = await getBlogSeries();
const highlightedTags = [...new Set(posts.flatMap((post) => post.data.tags))].slice(0, 12);
---

<BaseLayout
  title={`Blog · ${site.name}`}
  description="Notes on systems, networking, terminals, and things worth writing down."
>
  <main class="site-frame" id="main-content">
    <SiteHeader active="blog" />

    <section class="window-panel">
      <section class="panel-section">
        <div class="section-heading">
          <h1 class="panel-title">Blog</h1>
          <hr />
        </div>

        <p class="section-copy">
          Notes on systems, networking, terminals, and whatever feels worth writing down.
        </p>
      </section>

      <hr class="panel-divider" />

      <section class="panel-section">
        <div class="section-heading">
          <h2 class="panel-title panel-title-secondary">Archive overview</h2>
          <hr />
        </div>

        <p class="section-copy">Browse the series first, then drop into the full post list below.</p>

        {seriesGroups.length > 0 ? (
          <div class="chip-cloud">
            {seriesGroups.map((series) => (
              <a class="chip-link" href={`${baseUrl}blog/series/${series.slug}/`}>
                {series.name} series
              </a>
            ))}
          </div>
        ) : null}

        {highlightedTags.length > 0 ? (
          <div class="chip-cloud is-muted">
            {highlightedTags.map((tag) => (
              <span class="chip-link chip-static">#{tag}</span>
            ))}
          </div>
        ) : null}
      </section>

      <hr class="panel-divider" />

      <section class="panel-section" id="posts">
        <PostTable posts={posts} />
      </section>
    </section>

    <SiteFooter />
  </main>
</BaseLayout>
