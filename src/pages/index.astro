---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostTable from "../components/PostTable.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { getBlogPosts } from "../data/blog";
import { site } from "../data/site";

const baseUrl = import.meta.env.BASE_URL;
const blogHref = `${baseUrl}blog/`;
const posts = await getBlogPosts();
const featuredPosts = posts.slice(0, 3);
---

<BaseLayout title={`${site.name} · ${site.titleSuffix}`} description={site.intro}>
  <main class="site-frame" id="main-content">
    <SiteHeader active="home" />

    <section class="window-panel">
      <section class="panel-section">
        <div class="section-heading">
          <h1 class="panel-title">Hello</h1>
          <hr />
        </div>

        <div class="home-grid">
          <div class="intro-copy">
            <p class="body-copy home-kicker">{site.titleSuffix}</p>

            <blockquote class="home-quote">
              <em>{site.intro}</em>
            </blockquote>

            <p class="body-copy">
              This is the small archive I use to keep posts, notes, and important links in one
              place instead of scattering them across private documents.
            </p>

            <div class="action-row">
              <a class="tool-button tool-button-accent" href={blogHref}>Browse archive</a>
              <a class="tool-button" href={site.links.email}>Email</a>
              <a class="tool-button" href={site.links.github} target="_blank" rel="noopener">
                GitHub
              </a>
            </div>
          </div>

          <aside class="note-panel">
            <div class="note-panel-title">Now</div>
            <ul class="note-list">
              {site.now.map((item) => <li>{item}</li>)}
            </ul>
          </aside>
        </div>
      </section>

      <hr class="panel-divider" />

      <section class="panel-section" id="writing">
        <div class="section-heading">
          <h2 class="panel-title panel-title-secondary">Recent writing</h2>
          <hr />
        </div>

        <p class="section-copy">Latest entries from the archive.</p>

        <PostTable posts={featuredPosts} />

        <div class="section-actions">
          <a class="tool-button" href={blogHref}>Browse archive</a>
        </div>
      </section>

      <hr class="panel-divider" />

      <section class="panel-section">
        <div class="section-heading">
          <h2 class="panel-title panel-title-secondary">Links</h2>
          <hr />
        </div>

        <p class="section-copy">A few direct paths into the site and related profiles.</p>

        <table class="info-table">
          <tbody>
            {site.projects.map((project) => (
              <tr class="info-table-row">
                <td class="info-key">{project.tag}</td>
                <td class="info-value">
                  <a
                    class="info-link"
                    href={project.url}
                    target={project.url.startsWith("http") ? "_blank" : undefined}
                    rel={project.url.startsWith("http") ? "noopener" : undefined}
                  >
                    {project.name}
                  </a>
                  <span class="info-detail">{project.description}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <hr class="panel-divider" />

      <section class="panel-section" id="contact">
        <div class="section-heading">
          <h2 class="panel-title panel-title-secondary">Contact</h2>
          <hr />
        </div>

        <p class="section-copy">The fastest ways to reach me or find the source for this site.</p>

        <table class="info-table">
          <tbody>
            <tr class="info-table-row">
              <td class="info-key">Email</td>
              <td class="info-value">
                <a class="info-link" href={site.links.email}>
                  xindan.zhang@mail.utoronto.ca
                </a>
              </td>
            </tr>
            <tr class="info-table-row">
              <td class="info-key">GitHub</td>
              <td class="info-value">
                <a class="info-link" href={site.links.github} target="_blank" rel="noopener">
                  XindanZhang
                </a>
              </td>
            </tr>
            <tr class="info-table-row">
              <td class="info-key">Location</td>
              <td class="info-value">{site.location}</td>
            </tr>
            <tr class="info-table-row">
              <td class="info-key">Status</td>
              <td class="info-value">{site.availability}</td>
            </tr>
          </tbody>
        </table>
      </section>
    </section>

    <SiteFooter />
  </main>
</BaseLayout>
