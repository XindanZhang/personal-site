---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatBlogDate, getBlogPosts, getBlogSlug } from "../data/blog";
import { site } from "../data/site";

const year = new Date().getFullYear();
const baseUrl = import.meta.env.BASE_URL;
const blogHref = `${baseUrl}blog/`;
const posts = await getBlogPosts();
const featuredPosts = posts.slice(0, 3);
---

<BaseLayout title={`${site.name} · ${site.role}`} description={site.intro}>
  <div class="page-glow page-glow-left"></div>
  <div class="page-glow page-glow-right"></div>
  <div class="grid-haze"></div>

  <main class="site-shell" id="main-content">
    <nav class="topbar" aria-label="Primary">
      <a class="brand-lockup" href={baseUrl}>
        <span class="brand-mark">XZ</span>
        <span class="brand-copy">
          <strong>{site.name}</strong>
          <span>{site.role}</span>
        </span>
      </a>

      <div class="topbar-links">
        <a href="#focus">Focus</a>
        <a href="#work">Projects</a>
        <a href="#writing">Writing</a>
        <a href="#contact">Contact</a>
      </div>

      <a class="button button-quiet" href={blogHref}>Read blog</a>
    </nav>

    <section class="hero-panel" id="about">
      <div class="hero-copy">
        <p class="eyebrow">{site.role}</p>
        <h1 class="hero-title">{site.headline}</h1>
        <p class="hero-summary">{site.intro}</p>

        <div class="hero-actions">
          <a class="button button-primary" href={site.links.email}>Email me</a>
          <a class="button button-secondary" href={site.links.github} target="_blank" rel="noopener">
            GitHub
          </a>
          <a class="button button-secondary" href={blogHref}>Writing</a>
        </div>

        <dl class="meta-strip">
          <div>
            <dt>Location</dt>
            <dd>{site.location}</dd>
          </div>
          <div>
            <dt>Status</dt>
            <dd>{site.status}</dd>
          </div>
          <div>
            <dt>Availability</dt>
            <dd>{site.availability}</dd>
          </div>
        </dl>
      </div>

      <div class="hero-aside">
        <section class="glass-card signal-card">
          <p class="card-label">Current vector</p>
          <ul class="signal-list">
            {site.now.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="glass-card system-card" aria-label="Research map">
          <p class="card-label">Research map</p>
          <div class="system-map">
            <div class="system-node system-node-core">systems</div>
            <div class="system-node system-node-top">networks</div>
            <div class="system-node system-node-left">measurement</div>
            <div class="system-node system-node-right">agents</div>
            <div class="system-node system-node-bottom">tooling</div>
          </div>
          <p class="system-note">
            Small tools, visible experiments, and documentation that survives the next iteration.
          </p>
        </section>
      </div>
    </section>

    <section class="section" id="focus">
      <div class="section-header">
        <div>
          <p class="eyebrow">How I work</p>
          <h2 class="section-title">Research interests with a builder&apos;s bias</h2>
        </div>
        <p class="section-copy">
          I prefer concrete systems over vague abstractions: build a tool, run it, inspect the
          output, then tighten the idea.
        </p>
      </div>

      <div class="info-grid">
        {site.focusAreas.map((area) => (
          <article class="info-card">
            <p class="info-kicker">{area.title}</p>
            <p>{area.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="work">
      <div class="section-header">
        <div>
          <p class="eyebrow">Selected projects</p>
          <h2 class="section-title">Things I&apos;ve been building lately</h2>
        </div>
        <p class="section-copy">
          A mix of research infrastructure, developer tools, and experiments designed to make
          complex workflows more inspectable.
        </p>
      </div>

      <div class="project-grid">
        {site.projects.map((project) => (
          <a class="project-card" href={project.url} target="_blank" rel="noopener">
            <div class="project-card-head">
              <span class="project-tag">{project.tag}</span>
              <span class="project-link">Open ↗</span>
            </div>
            <h3>{project.name}</h3>
            <p>{project.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section" id="writing">
      <div class="section-header">
        <div>
          <p class="eyebrow">Writing</p>
          <h2 class="section-title">Selected writing</h2>
        </div>
        <p class="section-copy">
          Lab notes, project logs, and short pieces I want to remember later instead of losing in a
          private folder.
        </p>
      </div>

      <div class="blog-grid">
        {featuredPosts.map((post) => (
          <a class="blog-card" href={`${blogHref}${getBlogSlug(post.id)}/`}>
            <div class="blog-card-meta">
              <span>{formatBlogDate(post.data.publishedAt, "medium")}</span>
              {post.data.featured ? <span>Featured</span> : null}
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.summary}</p>
            <ul class="tag-list" aria-label={`${post.data.title} tags`}>
              {post.data.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          </a>
        ))}
      </div>

      <div class="section-footer">
        <a class="text-link" href={blogHref}>Browse the full archive</a>
      </div>
    </section>

    <section class="contact-band" id="contact">
      <div>
        <p class="eyebrow">Contact</p>
        <h2 class="section-title">Want to compare notes or build something interesting?</h2>
      </div>
      <div class="contact-actions">
        <a class="button button-primary" href={site.links.email}>Send email</a>
        <a class="button button-secondary" href={site.links.github} target="_blank" rel="noopener">
          GitHub profile
        </a>
      </div>
    </section>

    <footer class="footer">
      <span>© {year} {site.name}</span>
      <a href={blogHref}>Blog</a>
    </footer>
  </main>
</BaseLayout>
