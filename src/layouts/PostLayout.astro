---
import BaseLayout from "./BaseLayout.astro";
import { formatBlogDate } from "../data/blog";
import PostToc from "../components/PostToc.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  sourceUrl?: string;
  publishedAt: Date;
  tags?: string[];
  series?: string;
  seriesHref?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, sourceUrl, publishedAt, tags = [], series, seriesHref, headings = [] } =
  Astro.props;
const blogHref = `${import.meta.env.BASE_URL}blog/`;
const badgePalette = [
  { background: "#d4a72c", text: "#111111" },
  { background: "#177a45", text: "#ffffff" },
  { background: "#1e4d8c", text: "#ffffff" },
  { background: "#c41e3a", text: "#ffffff" },
  { background: "#e85d04", text: "#111111" },
  { background: "#7c3aed", text: "#ffffff" },
  { background: "#4b5563", text: "#ffffff" },
];
const primaryLabel = series ? `${series} series` : (tags[0] ?? "NOTE").toUpperCase();

let hash = 0;
for (const char of primaryLabel) {
  hash = (hash * 31 + char.charCodeAt(0)) | 0;
}
const badgeTheme = badgePalette[Math.abs(hash) % badgePalette.length];
---

<BaseLayout title={`${title} · ${site.name}`} description={description}>
  <main class="site-frame" id="main-content">
    <SiteHeader active="blog" />

    <div class="post-layout">
      <article class="window-panel article-panel">
        <div class="panel-tools">
          <a class="tool-button" href={blogHref}>Back to Blog</a>
          <button class="tool-button" type="button" data-copy-link data-copy-default="Copy Link">
            Copy Link
          </button>
        </div>

        <section class="panel-section">
          <div class="meta-badges">
            <span
              class="panel-tag"
              style={`--tag-color: ${badgeTheme.background}; --tag-text: ${badgeTheme.text};`}
            >
              {primaryLabel}
            </span>
            {series && seriesHref ? <span class="row-index">Series</span> : null}
          </div>

          <h1 class="article-title">{title}</h1>

          <div class="article-meta">
            <span>Published {formatBlogDate(publishedAt, "long")}</span>
            {tags.length > 0 ? <span>{tags.join(", ")}</span> : null}
          </div>

          <p class="article-summary">
            <em>{description}</em>
          </p>
        </section>

        {(sourceUrl || seriesHref) && (
          <>
            <hr class="panel-divider" />
            <section class="panel-section">
              <div class="link-grid">
                {sourceUrl ? (
                  <div class="link-card">
                    <span class="link-card-label">Source</span>
                    <a href={sourceUrl} target="_blank" rel="noopener">
                      Official site
                    </a>
                  </div>
                ) : null}

                {series && seriesHref ? (
                  <div class="link-card">
                    <span class="link-card-label">Series</span>
                    <a href={seriesHref}>{`Part of the ${series} series`}</a>
                  </div>
                ) : null}
              </div>
            </section>
          </>
        )}

        <hr class="panel-divider" />

        <div class="article-content">
          <slot />
        </div>
      </article>

      <PostToc headings={headings} />
    </div>

    <SiteFooter />
  </main>

  <script is:inline>
    document.addEventListener("click", async (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const button = target.closest("[data-copy-link]");
      if (!(button instanceof HTMLButtonElement)) return;

      const defaultLabel = button.dataset.copyDefault ?? "Copy Link";

      try {
        await navigator.clipboard.writeText(window.location.href);
        button.textContent = "Copied";
      } catch {
        button.textContent = "Copy failed";
      }

      window.setTimeout(() => {
        button.textContent = defaultLabel;
      }, 1200);
    });
  </script>
</BaseLayout>
