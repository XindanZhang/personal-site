---
import BaseLayout from "./BaseLayout.astro";
import { formatBlogDate } from "../data/blog";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  tags?: string[];
}

const { title, description, publishedAt, tags = [] } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const homeHref = baseUrl;
const blogHref = `${baseUrl}blog/`;
---

<BaseLayout title={`${title} · ${site.name}`} description={description}>
  <div class="page-glow page-glow-left"></div>
  <div class="page-glow page-glow-right"></div>
  <div class="grid-haze"></div>

  <main class="site-shell" id="main-content">
    <nav class="topbar" aria-label="Primary">
      <a class="brand-lockup" href={homeHref}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-copy">
          <strong>{site.name}</strong>
          <span>Post view</span>
        </span>
      </a>

      <div class="topbar-links">
        <a href={homeHref}>Home</a>
        <a href={blogHref}>Blog</a>
        <a href={`${homeHref}#contact`}>Contact</a>
      </div>
    </nav>

    <article class="post-shell">
      <p class="eyebrow">Published {formatBlogDate(publishedAt, "long")}</p>
      <h1 class="post-title">{title}</h1>
      <p class="post-summary">{description}</p>

      {tags.length > 0 ? (
        <ul class="tag-list" aria-label="Post tags">
          {tags.map((tag) => <li>{tag}</li>)}
        </ul>
      ) : null}

      <div class="post-content">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>
